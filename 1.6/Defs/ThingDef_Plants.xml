<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="WaterPlantBase">
        <defName>RT_ForkedLotus</defName>
        <label>forked lotus</label>
        <description>A mutant variety of lotus that evolved in waters bordering polluted wastelands. Its adaptations made it very hardy, able to survive in pollution and salty waters alike. However, it became unable to bear fruit and survive in the wild. Despite its origin, it's still quite beautiful.</description>
        <statBases>
            <MaxHitPoints>85</MaxHitPoints>
            <Beauty>14</Beauty>
            <BeautyOutdoors>14</BeautyOutdoors>
        </statBases>
        <graphicData>
            <texPath>Things/Plant/ForkedLotus</texPath>
            <graphicClass>Graphic_Random</graphicClass>
        </graphicData>
        <ingestible>
            <preferability>NeverForNutrition</preferability>
        </ingestible>
        <selectable>true</selectable>
        <plant>
            <topWindExposure>0.1</topWindExposure>
            <growDays>1.5</growDays>
            <lifespanDaysPerGrowDays>5</lifespanDaysPerGrowDays>
            <sowWork>750</sowWork>
            <visualSizeRange>0.5~0.6</visualSizeRange>
            <purpose>Beauty</purpose>
            <pollution>Any</pollution>
            <sowTags>
                <li>RT_Saltwater</li>
                <li>Decorative</li>
            </sowTags>
        </plant>
        <modExtensions>
            <li Class="RT_Saltwater.PlantPreferenceModExtension">
                <plantPreference>Either</plantPreference>
            </li>
        </modExtensions>
        <!--<comps>
            <li Class="CompProperties_Glower">
                <glowRadius>5</glowRadius>
                <glowColor>(150,150,20,0)</glowColor>
            </li>
        </comps>-->
    </ThingDef>
</Defs>
