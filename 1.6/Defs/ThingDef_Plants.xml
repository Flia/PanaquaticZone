<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="PlantBaseNonEdible">
        <defName>RT_Swiftcoral</defName>
        <label>swiftcoral</label>
        <description>A genetically-engineered coral which grows very fast. It is a renewable source of limestone, useful for colonies with little land but a lot of water.</description>
        <statBases>
            <MaxHitPoints>300</MaxHitPoints>
            <Flammability>0</Flammability>
        </statBases>
        <selectable>true</selectable>
        <neverMultiSelect>false</neverMultiSelect>
        <graphicData>
            <texPath>Things/Plant/Swiftcoral</texPath>
            <graphicClass>Graphic_Random</graphicClass>
        </graphicData>
        <plant>
            <pollution>Any</pollution>
            <completelyIgnoreFertility>true</completelyIgnoreFertility>
            <growDays>2</growDays>
            <harvestWork>800</harvestWork>
            <lifespanDaysPerGrowDays>9</lifespanDaysPerGrowDays>
            <harvestedThingDef>ChunkLimestone</harvestedThingDef>
            <harvestYield>1</harvestYield>
            <harvestTag>Standard</harvestTag>
            <purpose>Misc</purpose>
            <neverBlightable>true</neverBlightable>
            <blockAdjacentSow>true</blockAdjacentSow>
            <sowTags>
                <li>RT_Saltwater</li>
            </sowTags>
        </plant>
    </ThingDef>

    <ThingDef ParentName="WaterPlantBase">
        <defName>Plant_LotusPolluted</defName>
        <label>forked lotus</label>
        <description>A mutant variety of lotus, no less beautiful for its origin. Something beautiful *can* grow from something ugly.</description>
        <statBases>
            <MaxHitPoints>85</MaxHitPoints>
            <Beauty>14</Beauty>
            <BeautyOutdoors>14</BeautyOutdoors>
        </statBases>
        <graphicData>
            <texPath>Things/Plant/Lotus</texPath>
            <graphicClass>Graphic_Random</graphicClass>
        </graphicData>
        <ingestible>
            <preferability>NeverForNutrition</preferability>
        </ingestible>
        <selectable>true</selectable>
        <plant>
            <topWindExposure>0.1</topWindExposure>
            <growDays>1.5</growDays>
            <lifespanDaysPerGrowDays>5</lifespanDaysPerGrowDays>
            <visualSizeRange>0.5~0.6</visualSizeRange>
            <purpose>Beauty</purpose>
            <pollution>PollutedOnly</pollution>
            <sowTags>
                <li>RT_Saltwater</li>
            </sowTags>
            <wildTerrainTags>
                <li>WaterMarshy</li>
                <li>WaterFreshShallowStill</li>
            </wildTerrainTags>
        </plant>
        <comps>
            <li Class="CompProperties_Glower">
                <glowRadius>5</glowRadius>
                <glowColor>(150,150,20,0)</glowColor>
            </li>
        </comps>
    </ThingDef>
</Defs>
