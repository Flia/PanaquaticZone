<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_WoodKelp" or defName="Stagz_DarkAlgae"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="Stagz_WoodKelp" or defName="Stagz_DarkAlgae"]</xpath>
        <value>
            <li Class="PanaquaticZone.ModExtension_PlantSalinityPreference">
                <plantPreference>Euryhaline</plantPreference>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_RawDarkAlgae"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>
</Patch>