<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_WoodKelp"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Stagz_WoodKelp"]/plant/sowTags</xpath>
        <value>
            <li>RT_Saltwater</li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_DarkAlgae"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Stagz_DarkAlgae"]/plant/sowTags</xpath>
        <value>
            <li>RT_Saltwater</li>
        </value>
    </Operation>
    
    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_RawDarkAlgae"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>
</Patch>