<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationRemove">
        <xpath>/Defs/DesignationCategoryDef[defName = "Zone"]/specialDesignatorClasses/li[text()="LTSBiosphere.Zones.Designator_ZoneAdd_Aquatic"]</xpath>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="LTS_Plant_RedRice" or defName="LTS_Plant_Mistveil"]</xpath>
        <value>
            <li Class="PanaquaticZone.ModExtension_PlantSalinityPreference">
                <plantPreference>Freshwater</plantPreference>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAttributeAdd">
        <xpath>Defs/ThingDef[defName="LTS_Plant_Aquaflume"]</xpath>
        <attribute>Name</attribute>
        <value>LTS_Plant_Aquaflume</value>
    </Operation>
    <Operation Class="PatchOperationAttributeAdd">
        <xpath>Defs/ThingDef[defName="LTS_Plant_Cattail"]</xpath>
        <attribute>Name</attribute>
        <value>LTS_Plant_Cattail</value>
    </Operation>
    <Operation Class="PatchOperationAttributeAdd">
        <xpath>Defs/ThingDef[defName="LTS_Plant_Goblet"]</xpath>
        <attribute>Name</attribute>
        <value>LTS_Plant_Goblet</value>
    </Operation>
</Patch>