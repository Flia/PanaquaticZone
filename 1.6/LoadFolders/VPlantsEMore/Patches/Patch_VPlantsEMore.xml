<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationRemove">
        <xpath>/Defs/DesignationCategoryDef[defName = "Zone"]/specialDesignatorClasses/li[text()="VanillaPlantsExpandedMorePlants.Designator_AquaticGrowingZone"]</xpath>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="VCE_Taro" or defName="VCE_Watercress" or defName="VCE_Lotus" or defName="VCE_WaterChestnut"]</xpath>
        <value>
            <li Class="PanaquaticZone.ModExtension_PlantSalinityPreference">
                <plantPreference>Freshwater</plantPreference>
            </li>
        </value>
    </Operation>
</Patch>
