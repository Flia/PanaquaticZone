<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/DesignationCategoryDef[defName = "Zone"]/specialDesignatorClasses</xpath>
        <value>
            <li>RTSaltwaterZone.Designator_ZoneAdd_Saltwater</li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_WoodKelp"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Stagz_WoodKelp"]/plant/sowTags</xpath>
        <value>
            <li>RT_Merren_Saltwater</li>
            <li MayRequire="LimeTreeSnake.Biosphere">Water</li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_DarkAlgae"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Stagz_DarkAlgae"]/plant/sowTags</xpath>
        <value>
            <li>RT_Merren_Saltwater</li>
            <li MayRequire="LimeTreeSnake.Biosphere">Water</li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAttributeRemove">
        <xpath>Defs/ThingDef[defName="Stagz_RawDarkAlgae"]</xpath>
        <attribute>MayRequire</attribute>
    </Operation>
</Patch>